# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site-specific tenant UUID.
# Alternatively, hardcode this in src/lib/supabase/tenant.ts.
NEXT_PUBLIC_TENANT_ID=

# Storage bucket for admin image uploads.
SUPABASE_IMAGE_BUCKET=images

# Contact form — Nodemailer SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
CONTACT_TO=
